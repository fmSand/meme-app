<!DOCTYPE html>
<html lang="en">

<head>
  <title>Memes Overview</title>
  <%- include('./partials/head.ejs') %>
    <link rel="stylesheet" href="/stylesheets/memes.css">
</head>

<body class="position-relative" data-bs-spy="scroll">
  <%- include('./partials/navbar.ejs') %>

    <header class="mt-5 pt-3">
      <div class="header-section p-5 pb-4 rounded-0">
        <div class="container-fluid">
          <div class="row justify-content-center align-items-center text-center ">
            <div class="col-md-auto">
              <h1 class="display-2 fw-bold mb-3 text-center">Meme Central</h1>
              <p class="lead text-center">Meme hunting made easy! <br> Find classics, discover new favorites, and track what you've seen</p>
            </div>
          </div>

          <!-- SEARCH BAR  -->
          <div class="container d-flex justify-content-center my-4 ">
            <form action="/memes" method="GET" class="d-flex search-form w-100" style="max-width: 700px;">
              <div class="input-group">
                <span class="input-group-text bg-white border-end-0">
                  <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="search" class="form-control border-start-0" placeholder="Search memes..."
                  value="<%= search %>">
                <button type="submit" class="btn btn-search">Search</button>
                <% if (search) { %>
                  <a href="/memes" class="btn btn-clear">Clear</a>
                  <% } %>
              </div>
            </form>
          </div>
        </div>
      </div>
    </header>

    <section class="container">
      <!-- ALERTS -->
      <div class="alerts mb-4 mt-3">
        <% if (!isAuthenticated) { %>
          <div class="alert alert-secondary alert-dismissible fade show" role="alert">
            <a href="/auth/login">Login</a> to view meme details.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
          <% } %>
            <% if (error==='notloaded' ) { %>
              <div class="alert alert-danger">
                Memes could not be loaded. Please try again.
                <a href="/memes" class="btn btn-sm btn-light ms-2">Retry</a>
              </div>
              <% } %>
      </div>

      <!-- MEME TABLE -->
      <div class="table-responsive-lg">
        <table class="table align-middle text-nowrap" id="memes-table">
          <thead>
            <tr>
              <th scope="col">Image</th>
              <th scope="col">Name</th>
              <% if (isAuthenticated) { %>
                <th scope="col">Options</th>
                <% } %>
            </tr>
          </thead>
          <tbody>
            <% if (memes && memes.length> 0) { %>
              <% memes.forEach(meme=> { %>
                <tr class="<%= viewedMemes && viewedMemes[meme.id] ? 'viewed-meme' : '' %>"
                  data-meme-id="<%= meme.id %>">
                  <td>
                    <!--NOTE: Inline style is dynamic using EJS. Linter may show a false error here, but this is valid and renders correctly.-->
                    <img src="<%= meme.url %>" alt="<%= meme.name %>" class="meme-thumbnail" style="width: <%= meme.thumbWidth %>px;"/>
                  </td>
                  <td>
                    <%= meme.name %>
                  </td>
                  <% if (isAuthenticated) { %>
                    <td>
                      <button
                        class="btn btn-sm <%= viewedMemes && viewedMemes[meme.id] ? 'viewed-btn' : 'details-btn' %>"
                        data-meme="<%= JSON.stringify(meme) %>">

                        <% if (viewedMemes && viewedMemes[meme.id]) { %>
                          <span>Details<i class="bi bi-eye-fill ms-1"></i></span>
                          <% } else { %>
                            Details
                            <% } %>
                      </button>

                    </td>
                    <% } %>
                </tr>
                <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="<%= isAuthenticated ? 3 : 2 %>" class="empty-state text-center">No memes found
                      </td>
                    </tr>
                    <% } %>
          </tbody>
        </table>
      </div>
    </section>
    <%- include('./partials/scripts.ejs') %>   
</body>
</html>